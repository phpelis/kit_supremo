# CHATWOOT CONFIGURATION
# Obtido em Profille Settings -> Access Token
CHATWOOT_API_TOKEN=your_api_token_here

# Obtido na URL do painel: /app/accounts/{ID}
CHATWOOT_ACCOUNT_ID=1

# Ex: https://app.chatwoot.com ou sua instância self-hosted
CHATWOOT_API_URL=https://app.chatwoot.com

# Segredo para validação de webhooks (opcional, mas recomendado)
# Obtido em Settings -> Integrations -> Webhooks -> Secret
CHATWOOT_WEBHOOK_SECRET=your_webhook_secret_here
